{
	"name": "contact-form",
	"version": "1.0.0",
	"license": "MIT",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"dev:all": "pnpm run build:css --watch & pnpm run build:js --watch & tsx watch src/server.ts",
		"start": "node dist/server.js",
		"build": "pnpm run build:css && pnpm run build:js && tsc",
		"build:css": "tailwindcss -i src/style.css -o public/style.css",
		"build:js": "esbuild src/client.ts --bundle --minify --outfile=public/js/client.js",
		"lint": "oxlint .",
		"format": "oxfmt . --write",
		"format:check": "oxfmt . --check"
	},
	"dependencies": {
		"cors": "2.8.6",
		"dotenv": "17.4.1",
		"express": "5.2.1",
		"multiparty": "4.2.3",
		"nodemailer": "8.0.5",
		"express-rate-limit": "^8.3.2"
	},
	"devDependencies": {
		"@tailwindcss/cli": "4.2.2",
		"@types/cors": "2.8.19",
		"@types/express": "5.0.6",
		"@types/multiparty": "4.2.1",
		"@types/node": "25.5.2",
		"@types/nodemailer": "8.0.0",
		"esbuild": "0.28.0",
		"oxfmt": "0.43.0",
		"oxlint": "1.58.0",
		"tailwindcss": "4.2.2",
		"tsx": "4.21.0",
		"typescript": "6.0.2"
	}
}
